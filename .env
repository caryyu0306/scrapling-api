# ============================================================
# Scrapling API 基本設定
# ============================================================

# API 驗證密鑰。
# 呼叫 POST /scrape 時，HTTP Header 必須帶入相同的值：
# x-api-key: YOUR_API_KEY
# 正式部署前請改成夠長、無法猜測的隨機密鑰。
API_KEY=123456


# ============================================================
# 靜態抓取設定：AsyncFetcher
# ============================================================

# 等待靜態網頁 HTTP 回應的最長時間。
# 單位：秒。建議值：20-60。
STATIC_TIMEOUT=20

# 靜態請求失敗時的重試次數。
# 建議值：1-3。數值越高，失敗請求等待的總時間越長。
STATIC_RETRIES=2

# 靜態請求是否加入類似瀏覽器的 HTTP Headers。
# 可用值：true / false。大多數公開網站建議保持 true。
STATIC_STEALTHY_HEADERS=true


# ============================================================
# 動態抓取設定：DynamicFetcher
# ============================================================

# 瀏覽器載入動態頁面的最長時間。
# 單位：毫秒。60000 = 60 秒。
# 建議值：一般網站 30000、JavaScript 網站 60000、很慢的網站 90000。
DYNAMIC_TIMEOUT=10000

# 頁面導航後，額外固定等待多久才執行頁面互動並讀取 HTML。
# 單位：毫秒。5000 = 5 秒。
# 內容較晚出現時可提高，想加快回應速度時可降低。
DYNAMIC_WAIT=1000

# 是否等待瀏覽器網路活動進入閒置狀態。
# 可用值：true / false。大多數 JavaScript 網站建議保持 true。
DYNAMIC_NETWORK_IDLE=true

# 動態抓取時是否阻擋 CSS、圖片、字型等資源。
# 可用值：true / false。
# false 會完整載入頁面，對 myF5 這類依賴前端資源的網站較安全。
# true 可能較快，但部分網站會失敗或回傳不完整內容。
DYNAMIC_DISABLE_RESOURCES=false

# 同時允許幾個 DynamicFetcher 執行。
# 每個 dynamic 請求都會啟動瀏覽器，建議小型 VPS 設 1-2。
DYNAMIC_CONCURRENCY=2

# dynamic 請求排隊等待 semaphore 的最長時間。
# 單位：秒。超過會回傳 503，避免請求無限等待。
DYNAMIC_QUEUE_TIMEOUT=120

# 是否啟用 DynamicFetcher basic stealth 強化。
# 這不會改用第三方 solver，也不會升級到 StealthyFetcher；
# 只補 UA、語系、時區、viewport 與常見自動化標記隱藏。
DYNAMIC_STEALTH_BASIC=true

# dynamic browser context 的語系與時區。
DYNAMIC_LOCALE=zh-TW
DYNAMIC_TIMEZONE=Asia/Taipei
DYNAMIC_ACCEPT_LANGUAGE=zh-TW,zh;q=0.9,en;q=0.8

# dynamic browser context 的 viewport / screen 設定。
DYNAMIC_VIEWPORT_WIDTH=1366
DYNAMIC_VIEWPORT_HEIGHT=768
DYNAMIC_DEVICE_SCALE_FACTOR=1

# Chromium 啟動 flag。多個 flag 使用 | 分隔。
DYNAMIC_EXTRA_FLAGS=--disable-blink-features=AutomationControlled


# ============================================================
# User-Agent rotation
# ============================================================

# 是否每次 /scrape 請求隨機挑選一個 User-Agent。
# auto 模式若從 static fallback 到 dynamic，會沿用同一個 User-Agent。
USER_AGENT_ROTATION=true

# User-Agent 池。多個 UA 使用 | 分隔。
# 留空時會使用 main.py 內建的少量現代桌面瀏覽器 UA。
USER_AGENTS=


# ============================================================
# auto 模式判斷設定
# ============================================================

# auto 模式下，如果靜態 HTML 少於這個字元數，就改用 dynamic 抓取。
# 建議值：1000。如果 JavaScript 空殼頁沒有被辨識，可適度提高。
AUTO_MIN_HTML_LENGTH=1000

# 額外的 JavaScript 頁面辨識關鍵字。
# 靜態 HTML 命中時，auto 模式會改用 DynamicFetcher。
# 比對不分大小寫，多個關鍵字使用 | 分隔，不要使用逗號。
# main.py 內建的 CSS Error、Sorry to interrupt、Enable JavaScript 等關鍵字仍會保留。
EXTRA_JS_SIGNALS=安全驗證


# ============================================================
# 自動展開摺疊內容設定
# ============================================================

# DynamicFetcher 是否預設自動展開文章內常見的摺疊內容。
# 可用值：true / false。
# API 請求仍可使用 auto_expand 欄位，針對單次請求覆蓋此預設值。
AUTO_EXPAND_DEFAULT=true

# 自動展開時要搜尋的 CSS selector。
# 預設只尋找 main / article 內，且 aria-expanded="false" 的按鈕。
# 除非熟悉 CSS selector，否則建議保持預設值。
AUTO_EXPAND_SELECTOR=main button[aria-expanded='false'], main [role='button'][aria-expanded='false'], article button[aria-expanded='false'], article [role='button'][aria-expanded='false']

# 自動展開按鈕文字或 aria-label 必須包含的關鍵字。
# 比對不分大小寫，多個關鍵字使用 | 分隔。
# 例如 myF5 的 Applies to: 會命中 applies to。
AUTO_EXPAND_KEYWORDS=applies to|details|expand|load more|read more|see more|show more|view more|evaluated products

# 等待可展開按鈕出現的最長時間。
# 單位：毫秒。myF5 等較慢的 JavaScript 網站建議至少 15000。
AUTO_EXPAND_WAIT_TIMEOUT=15000

# 點擊展開按鈕後，再等待多久才讀取 HTML。
# 單位：毫秒。內容需要額外 API 載入時可提高。
AUTO_EXPAND_AFTER_CLICK_WAIT=1000


# ============================================================
# 手動 click_selectors 安全限制
# ============================================================

# 每次 API 請求允許提供的 click_selectors 數量上限。
# click_selectors 會真的操作目標頁面，請只指定無副作用的展開按鈕。
MAX_CLICK_SELECTORS=20

# 每個 selector 最多點擊多少個符合的可見元素。
# 避免 selector 太寬時點擊過多元素。
MAX_CLICKS_PER_SELECTOR=20

# 每次 API 請求允許提供的 input_values 數量上限。
# input_values 會在 dynamic 模式中先填入指定 input / textarea，再執行點擊。
MAX_INPUT_SELECTORS=20

# 每個 input_values 值允許的最大字元數，避免塞入過大的表單內容。
MAX_INPUT_VALUE_LENGTH=2000

# 填表單或等待 wait_for_selector 時，每個 selector 最長等待時間。
# 單位：毫秒。15000 = 15 秒。
FORM_ACTION_TIMEOUT=15000

# 單次請求 wait_after_actions 允許的最大等待時間。
# 單位：毫秒。60000 = 60 秒。
MAX_WAIT_AFTER_ACTIONS=60000


# ============================================================
# Markdown 前內容清理與降噪
# ============================================================

# 是否預設在 markdownify 前清理 HTML。
# 可用值：true / false。建議保持 true，避免 Nav/Footer/廣告吃掉大量 token。
CLEAN_CONTENT_DEFAULT=true

# 自動挑選主體內容時使用的 CSS selector 候選。
# 系統會選文字量最多且超過 CONTENT_MIN_TEXT_LENGTH 的節點。
# 多個 selector 使用 | 分隔。
CONTENT_SELECTORS=article|main|[role='main']|#content|#main-content|.content|.main-content|.post-content|.entry-content|.article-content

# 主體候選內容至少要有多少文字才會被採用；不足時會退回 body。
CONTENT_MIN_TEXT_LENGTH=200

# markdownify 前一律刪除的 HTML tag。
# 建議保留 script/style/nav/footer/aside 等噪音節點。
REMOVE_TAGS=script|style|noscript|template|nav|footer|aside|iframe|svg|canvas|form|input|select|textarea|button

# markdownify 前一律刪除的 CSS selector。
# 用於廣告、Cookie 橫幅、社群分享、推薦文章等常見噪音。
REMOVE_SELECTORS=[role='navigation']|[role='banner']|[role='contentinfo']|[aria-hidden='true']|.ad|.ads|.advertisement|.banner|.cookie|.cookie-banner|.cookies|.footer|.menu|.nav|.navbar|.newsletter|.popup|.sidebar|.social-share|.subscribe|.related-posts|.recommended|#ad|#ads|#footer|#header|#nav|#sidebar

# 每次 API 請求允許額外提供的 remove_selectors 數量上限。
MAX_CLEANING_SELECTORS=50
