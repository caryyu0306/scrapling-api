# API 驗證密鑰。
# 呼叫 API 時，HTTP Header 必須帶入相同的值：
# x-api-key: YOUR_API_KEY
# 正式部署前，請將範例值換成夠長的隨機密鑰。
API_KEY=123456

# AsyncFetcher 等待靜態網頁回應的最長時間。
# 單位：秒。建議值：20-60。
STATIC_TIMEOUT=20

# 靜態請求失敗時的重試次數。
# 建議值：1-3。數值越高，失敗請求等待的總時間越長。
STATIC_RETRIES=2

# 靜態請求是否加入類似瀏覽器的 HTTP Headers。
# 可用值：true / false。大多數公開網站建議保持 true。
STATIC_STEALTHY_HEADERS=true

# DynamicFetcher 允許瀏覽器載入頁面的最長時間。
# 單位：毫秒。60000 = 60 秒。
# 建議值：一般網站 30000、JavaScript 網站 60000、很慢的網站 90000。
DYNAMIC_TIMEOUT=10000

# 頁面載入後，額外固定等待多久才讀取 HTML。
# 單位：毫秒。5000 = 5 秒。
# 內容較晚出現時可提高，想加快回應速度時可降低。
DYNAMIC_WAIT=5000

# 是否等待瀏覽器網路活動進入閒置狀態後才讀取頁面。
# 可用值：true / false。大多數 JavaScript 網站建議保持 true。
DYNAMIC_NETWORK_IDLE=true

# 動態抓取時是否阻擋 CSS、圖片、字型等非必要資源。
# 可用值：true / false。
# false 會完整載入頁面，對 myF5 這類網站較安全。
# true 可能較快，但部分網站會失敗或回傳不完整內容。
DYNAMIC_DISABLE_RESOURCES=false

# auto 模式下，如果靜態 HTML 少於這個字元數，就改用 dynamic 抓取。
# 建議值：1000。如果 JavaScript 空殼頁沒有被辨識，可適度提高。
AUTO_MIN_HTML_LENGTH=1000

# 額外的 JavaScript 頁面辨識關鍵字，命中時 auto 模式會改用 dynamic。
# 比對不分大小寫。多個關鍵字請使用 | 分隔，不要使用逗號。
# 常用的內建關鍵字仍保留在 main.py。
# 範例：
# EXTRA_JS_SIGNALS=javascript required|please turn on javascript|app loading failed
EXTRA_JS_SIGNALS=
